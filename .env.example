# Copy to .env and fill in. .env is gitignored — keep real values in 1Password / Keychain.

# --- Alpaca (paper trading first) ---
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets   # market-data host (benchmark/SPY closes for the evaluation scorecard)

# --- Robinhood Agentic (OPTIONAL live execution — Phase 3, default OFF) ---
# Read-only LIVE panel (M1) and, behind the two human gates, live execution.
# The Agentic MCP authenticates via OAuth — connect it ONCE with
#   claude mcp add robinhood-trading --transport http https://agent.robinhood.com/mcp/trading
# then authorize in the browser. There is NO static token to paste; the dashboard
# reads your account THROUGH that authenticated `claude` CLI session.
# To show your account, set the ONE Agentic brokerage account number below (find
# it on a Robinhood statement / account settings — an 8-char code like 1AB23456).
# The dashboard reads ONLY this account (never enumerates your others) and the
# read is purely informational — it changes no trade gate. Default empty = the
# LIVE panel shows "not connected". Funding + opening the gates stay human-only,
# gated on a passing Phase 2 scorecard.
ROBINHOOD_AGENTIC_ACCOUNT_NUMBER=
# Broker gate (gate 1 of 2). Human attestation that the Robinhood Agentic
# account itself permits agent trading. Set to 1 ONLY after that account-level
# setting is on. The harness gate (gate 2) is a separate .claude/settings.json
# allow-list edit. BOTH must be open before any live order — see
# planning/two-gate-live-trading.md. Default empty = broker gate closed.
ROBINHOOD_BROKER_TRADING_ENABLED=
# Live funded capital (USD) the live caps treat as available when there is no
# live snapshot yet. The policy caps (weekly funding, max exposure, drawdown
# kill) live in the charter (strategy/charter.config.ts LIVE_LIMITS), not here.
# Default empty = treated as $0 (unfunded -> live buys blocked by the funded cap).
LIVE_FUNDED_CAPITAL_USD=

# --- Cloudflare R2 (encrypted data backups via rclone) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=personal-trading-agent-data
# rclone `crypt` secrets — client-side encryption of data/ before upload.
# Plaintext here (the scripts obscure them at runtime). Store the real values in
# 1Password / Keychain and NEVER lose them — without both you cannot decrypt backups.
R2_CRYPT_PASSWORD=
R2_CRYPT_SALT=

# --- Perplexity (OPTIONAL research provider — sanctioned metered-API exception) ---
# Default OFF. Fundamentals/earnings/catalyst research ONLY — never order pricing.
# NOTE: this is the pay-as-you-go Agent API, NOT your Perplexity Pro app subscription.
RESEARCH_PROVIDER=off            # off | perplexity | fmp
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar           # finance_search model; namespaced to perplexity/sonar for the Agent API
PERPLEXITY_DAILY_CALL_CAP=30     # hard daily invocation cap to bound cost
PERPLEXITY_MAX_OUTPUT_TOKENS=4000 # output-token budget; must fit the full structured JSON + summary (512 truncated it)
# PERPLEXITY_API_URL=https://api.perplexity.ai/v1/agent  # Agent API endpoint (override only if needed)

# --- Financial Modeling Prep (OPTIONAL fundamentals FALLBACK — free tier) ---
# Default OFF (no key). Cash-flow / fundamentals / dividend research ONLY — never order pricing.
# Consulted only when Perplexity is unavailable (Perplexity -> FMP -> unavailable). Each
# invocation issues several FMP requests; the cap counts invocations.
FMP_API_KEY=
FMP_DAILY_CALL_CAP=40            # hard daily invocation cap (free tier ~250 API calls/day)
# FMP_API_URL=https://financialmodelingprep.com/api/v3  # v3 base (override only if needed)

# --- Dashboard ---
PORT=3000

# --- Scheduled routines ---
# Bearer token the launchd runner sends to POST /api/routines/<id>. Set this so
# a stray localhost page can't trigger trading. Generate: openssl rand -hex 32
ROUTINE_TRIGGER_TOKEN=

# --- Reliability (M6) — all default OFF ---
# Dead-man switch (healthchecks.io). Per-routine slug pings: <base>/<key>/<routine>
# (and /<routine>/start, /<routine>/fail). A missed run alerts out-of-band.
HEALTHCHECKS_PING_KEY=
HEALTHCHECKS_BASE_URL=https://hc-ping.com
# Phone heartbeats on routine start/finish and any blocked order. off | ntfy | pushover
NOTIFY_PROVIDER=off
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
PUSHOVER_TOKEN=
PUSHOVER_USER=

# --- News scout (M7, optional) ---
# Comma-separated "url|Source" RSS feeds; blank uses sensible market defaults.
NEWS_FEEDS=
# Seconds between scout polls (used by scripts/news-scout.sh).
NEWS_SCOUT_INTERVAL=300
