# Secrets — never commit
.env
.env.local
.env.*.local

# Live-written data — backed up to Cloudflare R2 (encrypted), never committed
/data/

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts
/coverage
.vercel
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Claude Code — local machine-specific permission grants (the shared deny-list
# in .claude/settings.json IS committed; the local allow-list is not)
.claude/settings.local.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Playwright MCP scratch output (milestone screenshots, snapshots, console logs)
.playwright-mcp/

# Locally-installed agent skills (added via `npx skills add`) — tooling, not
# project source; reinstall locally rather than vendoring into the repo
.agents/skills/
.claude/skills/
skills-lock.json
